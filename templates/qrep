WITH QREP_SCHEMAS AS (
    SELECT 'IBMQREP_CAPPARMS' AS TABLE_NAME, 
           CURRENT SCHEMA AS CURRENT_SCHEMA, 
           'CAPTURE' AS TYPE
    FROM IBMQREP_CAPPARMS
    UNION ALL
    SELECT 'IBMQREP_APPLYPARMS', CURRENT SCHEMA, 'APPLY'
    FROM IBMQREP_APPLYPARMS
)
SELECT DISTINCT 
       CURRENT_SCHEMA AS QREP_SCHEMA,
       TYPE,
       (SELECT QMGR FROM IBMQREP_CAPPARMS WHERE 1=1 FETCH FIRST 1 ROW ONLY) AS CAPTURE_QMGR,
       (SELECT QMGR FROM IBMQREP_APPLYPARMS WHERE 1=1 FETCH FIRST 1 ROW ONLY) AS APPLY_QMGR
FROM QREP_SCHEMAS
ORDER BY QREP_SCHEMA;
